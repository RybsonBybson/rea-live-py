{
  "name": "rea-multiplayer",
  "author": "Ryba",
  "description": "Play Reaper multiplayer",
  "private": true,
  "version": "1.0.0",
  "main": "electron/app.cjs",
  "scripts": {
    "dev": "cross-env NODE_ENV=development concurrently --kill-others \"vite\" \"electron .\"",
    "build": "vite build",
    "pack": "electron-builder --dir",
    "build-win": "electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "directories": {
      "output": "build"
    },
    "asar": false,
    "files": [
      "electron/**/*",
      "dist/**/*",
      "!dist/resources/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/rea-multi.png"
    }
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "fs-extra": "^11.3.4",
    "googleapis": "^171.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1"
  }
}
